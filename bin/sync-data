#!/usr/bin/env bash
# bin/sync-data — 把本机 ~/.config/opencode/skills/ 的元数据同步到 data-mirror/
# 用法：
#   bin/sync-data         # 从用户级 skills 仓库同步三个核心元数据文件
#   bin/sync-data --check # 干跑，列出会变更的文件但不改动
#   bin/sync-data --diff-skills  # 打印 INDEX.md 新增了哪些 skill（agent 用，机读）
#
# 真相源：~/.config/opencode/skills/{INDEX.md, skills-graph.mmd, skills-graph.png}
# 镜像点：./data-mirror/{INDEX.md, skills-graph.mmd, skills-graph.png}

set -euo pipefail

REPO_ROOT="$(cd "$(dirname "$0")/.." && pwd)"
SKILLS_ROOT="${SKILLS_ROOT:-$HOME/.config/opencode/skills}"
MIRROR="$REPO_ROOT/data-mirror"

CHECK_ONLY=0
DIFF_SKILLS=0
if [[ "${1:-}" == "--check" ]]; then
    CHECK_ONLY=1
elif [[ "${1:-}" == "--diff-skills" ]]; then
    DIFF_SKILLS=1
fi

extract_skill_names() {
    grep -oE '\[[a-z0-9][a-z0-9-]+\]\(file:///[^)]+SKILL\.md\)' "$1" 2>/dev/null \
        | sed -E 's/^\[([^]]+)\].*/\1/' | sort -u
}

if [[ $DIFF_SKILLS -eq 1 ]]; then
    OLD="$MIRROR/INDEX.md"
    NEW="$SKILLS_ROOT/INDEX.md"
    if [[ ! -f "$NEW" ]]; then
        echo "❌ 缺源：$NEW" >&2; exit 1
    fi
    if [[ ! -f "$OLD" ]]; then
        echo "ALL"
        extract_skill_names "$NEW"
        exit 0
    fi
    diff <(extract_skill_names "$OLD") <(extract_skill_names "$NEW") \
        | awk '/^> /{print substr($0,3)}' | sort -u
    exit 0
fi

if [[ ! -d "$SKILLS_ROOT" ]]; then
    echo "❌ 真相源不存在：$SKILLS_ROOT" >&2
    exit 1
fi

mkdir -p "$MIRROR"

FILES=(INDEX.md skills-graph.mmd skills-graph.png)
CHANGED=0

for f in "${FILES[@]}"; do
    src="$SKILLS_ROOT/$f"
    dst="$MIRROR/$f"
    if [[ ! -f "$src" ]]; then
        echo "⚠️  缺源文件：$src（跳过）"
        continue
    fi
    if [[ ! -f "$dst" ]] || ! cmp -s "$src" "$dst"; then
        if [[ $CHECK_ONLY -eq 1 ]]; then
            echo "📝 会更新：$f"
        else
            cp "$src" "$dst"
            echo "✅ 同步：$f"
        fi
        CHANGED=$((CHANGED + 1))
    else
        echo "⏸  无变化：$f"
    fi
done

if [[ $CHECK_ONLY -eq 1 ]]; then
    echo ""
    if [[ $CHANGED -eq 0 ]]; then
        echo "🎯 data-mirror/ 已是最新，无需 sync。"
    else
        echo "📦 共 $CHANGED 个文件需 sync。运行 \`bin/sync-data\` 应用。"
    fi
    exit 0
fi

if [[ $CHANGED -gt 0 ]]; then
    echo ""
    echo "🎉 已同步 $CHANGED 个文件到 data-mirror/。"
fi
